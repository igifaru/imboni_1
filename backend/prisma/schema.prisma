generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model AdministrativeUnit {
  id                String               @id @default(cuid())
  name              String
  level             AdministrativeLevel
  code              String               @unique
  parentId          String?              @map("parent_id")
  createdAt         DateTime             @default(now()) @map("created_at")
  parent            AdministrativeUnit?  @relation("UnitHierarchy", fields: [parentId], references: [id])
  children          AdministrativeUnit[] @relation("UnitHierarchy")
  caseAssignments   CaseAssignment[]
  cases             Case[]
  communityChannels CommunityChannel[]
  leaderAssignments LeaderAssignment[]
  projects          Project[]

  @@map("administrative_units")
}

model User {
  id                 String              @id @default(cuid())
  role               UserRole            @default(CITIZEN)
  phone              String?             @unique
  email              String?             @unique
  password           String
  status             UserStatus          @default(ACTIVE)
  createdAt          DateTime            @default(now()) @map("created_at")
  name               String?
  profilePicture     String?             @map("profile_picture")
  auditLogs          AuditLog[]
  caseActions        CaseAction[]
  caseAssignments    CaseAssignment[]    @relation("AssignedLeader")
  cases              Case[]
  channelMemberships ChannelMembership[]
  channelMessages    ChannelMessage[]
  profile            CitizenProfile?
  leaderAssignments  LeaderAssignment[]
  notifications      Notification[]
  messageReactions   MessageReaction[]
  messageReadReceipts MessageReadReceipt[]
  verifications      CitizenVerification[]

  @@map("users")
}

model CommunityChannel {
  id                   String              @id @default(cuid())
  administrativeUnitId String              @map("administrative_unit_id")
  category             CaseCategory?
  type                 ChannelType         @default(COMMUNITY)
  name                 String
  createdAt            DateTime            @default(now()) @map("created_at")
  memberships          ChannelMembership[]
  messages             ChannelMessage[]
  administrativeUnit   AdministrativeUnit  @relation(fields: [administrativeUnitId], references: [id])

  @@unique([administrativeUnitId, category], name: "unique_unit_category_channel")
  @@map("community_channels")
}

model ChannelMembership {
  id        String           @id @default(cuid())
  userId    String           @map("user_id")
  channelId String           @map("channel_id")
  role      ChannelRole      @default(MEMBER)
  isMuted   Boolean          @default(false) @map("is_muted")
  joinedAt  DateTime         @default(now()) @map("joined_at")
  channel   CommunityChannel @relation(fields: [channelId], references: [id])
  user      User             @relation(fields: [userId], references: [id])

  @@unique([userId, channelId])
  @@map("channel_memberships")
}

model ChannelMessage {
  id          String           @id @default(cuid())
  content     String
  authorId    String           @map("author_id")
  channelId   String           @map("channel_id")
  isOfficial  Boolean          @default(false) @map("is_official")
  isPinned    Boolean          @default(false) @map("is_pinned")
  replyToId   String?          @map("reply_to_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  attachments Json?
  author      User             @relation(fields: [authorId], references: [id])
  channel     CommunityChannel @relation(fields: [channelId], references: [id])
  replyTo     ChannelMessage?  @relation("MessageReplies", fields: [replyToId], references: [id])
  replies     ChannelMessage[] @relation("MessageReplies")
  reactions   MessageReaction[]
  readReceipts MessageReadReceipt[]

  @@map("channel_messages")
}

model MessageReaction {
  id        String         @id @default(cuid())
  emoji     String
  userId    String         @map("user_id")
  messageId String         @map("message_id")
  createdAt DateTime       @default(now()) @map("created_at")
  user      User           @relation(fields: [userId], references: [id])
  message   ChannelMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId, emoji])
  @@map("message_reactions")
}

model MessageReadReceipt {
  id        String         @id @default(cuid())
  userId    String         @map("user_id")
  messageId String         @map("message_id")
  readAt    DateTime       @default(now()) @map("read_at")
  user      User           @relation(fields: [userId], references: [id])
  message   ChannelMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@unique([userId, messageId])
  @@map("message_read_receipts")
}


model LeaderAssignment {
  id                   String             @id @default(cuid())
  userId               String             @map("user_id")
  administrativeUnitId String             @map("administrative_unit_id")
  positionTitle        String             @map("position_title")
  startDate            DateTime           @map("start_date")
  endDate              DateTime?          @map("end_date")
  isActive             Boolean            @default(true) @map("is_active")
  administrativeUnit   AdministrativeUnit @relation(fields: [administrativeUnitId], references: [id])
  user                 User               @relation(fields: [userId], references: [id])

  @@map("leader_assignments")
}

model CitizenProfile {
  id              String          @id @default(cuid())
  userId          String          @unique @map("user_id")
  nationalId      String?         @unique @map("national_id")
  protectionLevel ProtectionLevel @default(ANONYMOUS) @map("protection_level")
  cell            String?
  country         String?         @default("Rwanda")
  district        String?
  province        String?
  sector          String?
  village         String?
  user            User            @relation(fields: [userId], references: [id])

  @@map("citizen_profiles")
}

model Case {
  id                   String              @id @default(cuid())
  caseReference        String              @unique @map("case_reference")
  category             CaseCategory
  urgency              CaseUrgency         @default(NORMAL)
  title                String
  description          String
  administrativeUnitId String              @map("administrative_unit_id")
  currentLevel         AdministrativeLevel @map("current_level")
  status               CaseStatus          @default(OPEN)
  submittedAnonymously Boolean             @default(false) @map("submitted_anonymously")
  submitterId          String?             @map("submitter_id")
  createdAt            DateTime            @default(now()) @map("created_at")
  resolvedAt           DateTime?           @map("resolved_at")
  actions              CaseAction[]
  assignments          CaseAssignment[]
  resolution           CaseResolution?
  administrativeUnit   AdministrativeUnit  @relation(fields: [administrativeUnitId], references: [id])
  submitter            User?               @relation(fields: [submitterId], references: [id])
  escalationEvents     EscalationEvent[]
  evidence             Evidence[]
  notifications        Notification[]

  @@index([caseReference])
  @@index([status])
  @@map("cases")
}

model CaseAssignment {
  id                   String             @id @default(cuid())
  caseId               String             @map("case_id")
  administrativeUnitId String             @map("administrative_unit_id")
  leaderId             String             @map("leader_id")
  assignedAt           DateTime           @default(now()) @map("assigned_at")
  deadlineAt           DateTime           @map("deadline_at")
  completedAt          DateTime?          @map("completed_at")
  escalationReason     String?            @map("escalation_reason")
  isActive             Boolean            @default(true) @map("is_active")
  extensionCount       Int                @default(0) @map("extension_count")
  extensionReason      String?            @map("extension_reason") // Added to track latest extension reason
  administrativeUnit   AdministrativeUnit @relation(fields: [administrativeUnitId], references: [id])
  case                 Case               @relation(fields: [caseId], references: [id])
  leader               User               @relation("AssignedLeader", fields: [leaderId], references: [id])

  @@index([caseId])
  @@index([deadlineAt])
  @@map("case_assignments")
}

model EscalationEvent {
  id            String              @id @default(cuid())
  caseId        String              @map("case_id")
  fromLevel     AdministrativeLevel @map("from_level")
  toLevel       AdministrativeLevel @map("to_level")
  triggeredBy   String              @default("SYSTEM") @map("triggered_by")
  triggerReason TriggerReason       @map("trigger_reason")
  triggeredAt   DateTime            @default(now()) @map("triggered_at")
  case          Case                @relation(fields: [caseId], references: [id])

  @@index([caseId])
  @@map("escalation_events")
}

model CaseAction {
  id          String     @id @default(cuid())
  caseId      String     @map("case_id")
  performedBy String     @map("performed_by")
  actionType  ActionType @map("action_type")
  notes       String?
  createdAt   DateTime   @default(now()) @map("created_at")
  case        Case       @relation(fields: [caseId], references: [id])
  performer   User       @relation(fields: [performedBy], references: [id])

  @@map("case_actions")
}

model AuditLog {
  id          String   @id @default(cuid())
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  action      String
  performedBy String?  @map("performed_by")
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  timestamp   DateTime @default(now())
  performer   User?    @relation(fields: [performedBy], references: [id])

  @@index([entityType, entityId])
  @@map("audit_logs")
}

model Notification {
  id        String              @id @default(cuid())
  userId    String              @map("user_id")
  caseId    String?             @map("case_id")
  channel   NotificationChannel
  message   String
  sentAt    DateTime?           @map("sent_at")
  createdAt DateTime            @default(now()) @map("created_at")
  case      Case?               @relation(fields: [caseId], references: [id])
  user      User                @relation(fields: [userId], references: [id])

  @@map("notifications")
}

model Evidence {
  id         String          @id @default(cuid())
  caseId     String          @map("case_id")
  type       EvidenceType
  url        String
  fileName   String          @map("file_name")
  fileSize   Int             @map("file_size")
  mimeType   String          @map("mime_type")
  createdAt  DateTime        @default(now()) @map("created_at")
  resolution CaseResolution?
  case       Case            @relation(fields: [caseId], references: [id], onDelete: Cascade)

  @@index([caseId])
  @@map("evidence")
}

model CaseResolution {
  id         String    @id @default(cuid())
  caseId     String    @unique @map("case_id")
  notes      String
  resolvedBy String    @map("resolved_by")
  resolvedAt DateTime  @default(now()) @map("resolved_at")
  evidenceId String?   @unique @map("evidence_id")
  case       Case      @relation(fields: [caseId], references: [id])
  evidence   Evidence? @relation(fields: [evidenceId], references: [id])

  @@map("case_resolutions")
}

enum AdministrativeLevel {
  VILLAGE
  CELL
  SECTOR
  DISTRICT
  PROVINCE
  NATIONAL
}

enum UserRole {
  CITIZEN
  LEADER
  ADMIN
  OVERSIGHT
  NGO
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum ProtectionLevel {
  ANONYMOUS
  PROTECTED
  IDENTIFIED
}

enum CaseCategory {
  JUSTICE
  HEALTH
  LAND
  INFRASTRUCTURE
  SECURITY
  SOCIAL
  EDUCATION
  OTHER
}

enum CaseUrgency {
  NORMAL
  HIGH
  EMERGENCY
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ESCALATED
  CLOSED
  PENDING_CONFIRMATION
  COMMUNITY
}

enum ActionType {
  ACKNOWLEDGED
  COMMENT
  STATUS_UPDATE
  ASSIGNMENT
  RESOLUTION
}

enum TriggerReason {
  TIME_EXPIRED
  EMERGENCY_OVERRIDE
  MANUAL_ESCALATION
}

enum NotificationChannel {
  SMS
  EMAIL
  PUSH
}

enum EvidenceType {
  IMAGE
  VIDEO
  AUDIO
  DOCUMENT
}

enum ChannelType {
  OFFICIAL
  COMMUNITY
}

enum ChannelRole {
  MEMBER
  MODERATOR
}

// ============================================
// PFTCV - Public Fund Transparency & Citizen Verification
// ============================================

model Project {
  id                   String               @id @default(cuid())
  projectCode          String               @unique @map("project_code")
  name                 String
  sector               ProjectSector
  description          String?
  administrativeUnitId String               @map("administrative_unit_id")
  gpsLatitude          Float?               @map("gps_latitude")
  gpsLongitude         Float?               @map("gps_longitude")
  approvedBudget       Float                @map("approved_budget")
  fundingSource        String?              @map("funding_source")
  implementingAgency   String?              @map("implementing_agency")
  expectedOutputs      String?              @map("expected_outputs")
  startDate            DateTime?            @map("start_date")
  endDate              DateTime?            @map("end_date")
  status               ProjectStatus        @default(PLANNED)
  riskLevel            RiskLevel            @default(NORMAL) @map("risk_level")
  riskScore            Int                  @default(0) @map("risk_score")
  verifiedPercentage   Int                  @default(0) @map("verified_percentage")
  createdAt            DateTime             @default(now()) @map("created_at")
  updatedAt            DateTime             @updatedAt @map("updated_at")
  administrativeUnit   AdministrativeUnit   @relation(fields: [administrativeUnitId], references: [id])
  fundReleases         FundRelease[]
  verifications        CitizenVerification[]

  @@index([sector])
  @@index([status])
  @@index([riskLevel])
  @@map("projects")
}

model FundRelease {
  id            String   @id @default(cuid())
  projectId     String   @map("project_id")
  amount        Float
  releaseDate   DateTime @map("release_date")
  releaseRef    String?  @map("release_ref")
  description   String?
  createdAt     DateTime @default(now()) @map("created_at")
  project       Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@map("fund_releases")
}

model CitizenVerification {
  id                String              @id @default(cuid())
  projectId         String              @map("project_id")
  verifierId        String?             @map("verifier_id")
  isAnonymous       Boolean             @default(false) @map("is_anonymous")
  deliveryStatus    DeliveryStatus      @map("delivery_status")
  completionPercent Int                 @default(0) @map("completion_percent")
  qualityRating     Int?                @map("quality_rating")
  comment           String?
  gpsLatitude       Float?              @map("gps_latitude")
  gpsLongitude      Float?              @map("gps_longitude")
  verifiedAt        DateTime            @default(now()) @map("verified_at")
  project           Project             @relation(fields: [projectId], references: [id], onDelete: Cascade)
  verifier          User?               @relation(fields: [verifierId], references: [id])
  evidence          VerificationEvidence[]

  @@index([projectId])
  @@map("citizen_verifications")
}

model VerificationEvidence {
  id             String              @id @default(cuid())
  verificationId String              @map("verification_id")
  type           EvidenceType
  url            String
  fileName       String              @map("file_name")
  fileSize       Int                 @map("file_size")
  mimeType       String              @map("mime_type")
  createdAt      DateTime            @default(now()) @map("created_at")
  verification   CitizenVerification @relation(fields: [verificationId], references: [id], onDelete: Cascade)

  @@index([verificationId])
  @@map("verification_evidence")
}

enum ProjectSector {
  ROADS
  HEALTH
  EDUCATION
  WATER
  SOCIAL_AID
  AGRICULTURE
  ENERGY
  OTHER
}

enum ProjectStatus {
  PLANNED
  IN_PROGRESS
  COMPLETED
  SUSPENDED
  CANCELLED
}

enum DeliveryStatus {
  FULLY_DELIVERED
  PARTIALLY_DELIVERED
  NOT_DELIVERED
  NOT_STARTED
}

enum RiskLevel {
  NORMAL
  NEEDS_REVIEW
  HIGH_RISK
}
