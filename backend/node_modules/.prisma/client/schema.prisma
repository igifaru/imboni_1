// Imboni Platform - Database Schema
// National Civic Governance Platform

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ============ ENUMS ============

enum AdministrativeLevel {
  VILLAGE // Umudugudu
  CELL // Akagari
  SECTOR // Umurenge
  DISTRICT // Akarere
  PROVINCE // Intara
  NATIONAL // Igihugu
}

enum UserRole {
  CITIZEN
  LEADER
  ADMIN
  OVERSIGHT
  NGO
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  INACTIVE
}

enum ProtectionLevel {
  ANONYMOUS
  PROTECTED
  IDENTIFIED
}

enum CaseCategory {
  JUSTICE
  HEALTH
  LAND
  INFRASTRUCTURE
  SECURITY
  SOCIAL
  EDUCATION
  OTHER
}

enum CaseUrgency {
  NORMAL
  HIGH
  EMERGENCY
}

enum CaseStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  ESCALATED
  CLOSED
}

enum ActionType {
  ACKNOWLEDGED
  COMMENT
  STATUS_UPDATE
  ASSIGNMENT
  RESOLUTION
}

enum TriggerReason {
  TIME_EXPIRED
  EMERGENCY_OVERRIDE
  MANUAL_ESCALATION
}

enum NotificationChannel {
  SMS
  EMAIL
  PUSH
}

// ============ MODELS ============

// 2.1 Administrative Hierarchy
model AdministrativeUnit {
  id        String               @id @default(cuid())
  name      String
  level     AdministrativeLevel
  code      String               @unique
  parentId  String?              @map("parent_id")
  parent    AdministrativeUnit?  @relation("UnitHierarchy", fields: [parentId], references: [id])
  children  AdministrativeUnit[] @relation("UnitHierarchy")
  createdAt DateTime             @default(now()) @map("created_at")

  leaderAssignments LeaderAssignment[]
  cases             Case[]
  caseAssignments   CaseAssignment[]

  @@map("administrative_units")
}

// 2.2 Users & Roles
model User {
  id        String     @id @default(cuid())
  role      UserRole   @default(CITIZEN)
  phone     String?    @unique
  email     String?    @unique
  password  String
  status    UserStatus @default(ACTIVE)
  createdAt DateTime   @default(now()) @map("created_at")

  profile           CitizenProfile?
  leaderAssignments LeaderAssignment[]
  caseAssignments   CaseAssignment[]   @relation("AssignedLeader")
  caseActions       CaseAction[]
  notifications     Notification[]
  auditLogs         AuditLog[]

  @@map("users")
}

// 2.2B Leader Assignments
model LeaderAssignment {
  id                   String             @id @default(cuid())
  userId               String             @map("user_id")
  user                 User               @relation(fields: [userId], references: [id])
  administrativeUnitId String             @map("administrative_unit_id")
  administrativeUnit   AdministrativeUnit @relation(fields: [administrativeUnitId], references: [id])
  positionTitle        String             @map("position_title")
  startDate            DateTime           @map("start_date")
  endDate              DateTime?          @map("end_date")
  isActive             Boolean            @default(true) @map("is_active")

  @@map("leader_assignments")
}

// 2.3 Citizen Identity (RESTRICTED ACCESS)
model CitizenProfile {
  id              String          @id @default(cuid())
  userId          String          @unique @map("user_id")
  user            User            @relation(fields: [userId], references: [id])
  nationalId      String?         @unique @map("national_id")
  protectionLevel ProtectionLevel @default(ANONYMOUS) @map("protection_level")

  @@map("citizen_profiles")
}

// 2.4 Case / Issue Management
model Case {
  id                   String              @id @default(cuid())
  caseReference        String              @unique @map("case_reference")
  category             CaseCategory
  urgency              CaseUrgency         @default(NORMAL)
  title                String
  description          String
  administrativeUnitId String              @map("administrative_unit_id")
  administrativeUnit   AdministrativeUnit  @relation(fields: [administrativeUnitId], references: [id])
  currentLevel         AdministrativeLevel @map("current_level")
  status               CaseStatus          @default(OPEN)
  submittedAnonymously Boolean             @default(false) @map("submitted_anonymously")
  submitterId          String?             @map("submitter_id")
  createdAt            DateTime            @default(now()) @map("created_at")
  resolvedAt           DateTime?           @map("resolved_at")

  assignments      CaseAssignment[]
  escalationEvents EscalationEvent[]
  actions          CaseAction[]
  notifications    Notification[]

  @@index([caseReference])
  @@index([status])
  @@map("cases")
}

// 2.5 Case Assignment
model CaseAssignment {
  id                   String             @id @default(cuid())
  caseId               String             @map("case_id")
  case                 Case               @relation(fields: [caseId], references: [id])
  administrativeUnitId String             @map("administrative_unit_id")
  administrativeUnit   AdministrativeUnit @relation(fields: [administrativeUnitId], references: [id])
  leaderId             String             @map("leader_id")
  leader               User               @relation("AssignedLeader", fields: [leaderId], references: [id])
  assignedAt           DateTime           @default(now()) @map("assigned_at")
  deadlineAt           DateTime           @map("deadline_at")
  completedAt          DateTime?          @map("completed_at")
  escalationReason     String?            @map("escalation_reason")
  isActive             Boolean            @default(true) @map("is_active")

  @@index([caseId])
  @@index([deadlineAt])
  @@map("case_assignments")
}

// 2.6 Escalation Events (IMMUTABLE)
model EscalationEvent {
  id            String              @id @default(cuid())
  caseId        String              @map("case_id")
  case          Case                @relation(fields: [caseId], references: [id])
  fromLevel     AdministrativeLevel @map("from_level")
  toLevel       AdministrativeLevel @map("to_level")
  triggeredBy   String              @default("SYSTEM") @map("triggered_by")
  triggerReason TriggerReason       @map("trigger_reason")
  triggeredAt   DateTime            @default(now()) @map("triggered_at")

  @@index([caseId])
  @@map("escalation_events")
}

// 2.7 Case Actions
model CaseAction {
  id          String     @id @default(cuid())
  caseId      String     @map("case_id")
  case        Case       @relation(fields: [caseId], references: [id])
  performedBy String     @map("performed_by")
  performer   User       @relation(fields: [performedBy], references: [id])
  actionType  ActionType @map("action_type")
  notes       String?
  createdAt   DateTime   @default(now()) @map("created_at")

  @@map("case_actions")
}

// 2.8 Audit Logs (APPEND-ONLY)
model AuditLog {
  id          String   @id @default(cuid())
  entityType  String   @map("entity_type")
  entityId    String   @map("entity_id")
  action      String
  performedBy String?  @map("performed_by")
  performer   User?    @relation(fields: [performedBy], references: [id])
  oldValue    Json?    @map("old_value")
  newValue    Json?    @map("new_value")
  timestamp   DateTime @default(now())

  @@index([entityType, entityId])
  @@map("audit_logs")
}

// 2.9 Notifications
model Notification {
  id        String              @id @default(cuid())
  userId    String              @map("user_id")
  user      User                @relation(fields: [userId], references: [id])
  caseId    String?             @map("case_id")
  case      Case?               @relation(fields: [caseId], references: [id])
  channel   NotificationChannel
  message   String
  sentAt    DateTime?           @map("sent_at")
  createdAt DateTime            @default(now()) @map("created_at")

  @@map("notifications")
}
