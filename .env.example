# Backend Environment Configuration

# Database
DATABASE_URL="postgresql://imboni:Imboni2025@localhost:5432/imboni?schema=public"

# JWT
JWT_SECRET="your-super-secure-jwt-secret-change-in-production"
JWT_EXPIRES_IN="7d"

# Services Ports
API_GATEWAY_PORT=3000
CASE_SERVICE_PORT=3001
ESCALATION_SERVICE_PORT=3002
NOTIFICATION_SERVICE_PORT=3003
AUDIT_SERVICE_PORT=3004
INTEGRATION_SERVICE_PORT=3005

# Redis
REDIS_URL="redis://localhost:6379"

# RabbitMQ
RABBITMQ_URL="amqp://imboni:imboni_mq_password@localhost:5672"

# SMS Gateway (Africa's Talking)
SMS_API_KEY=""
SMS_USERNAME=""
SMS_SENDER_ID="IMBONI"

# Email (SMTP)
SMTP_HOST="smtp.example.com"
SMTP_PORT=587
SMTP_USER=""
SMTP_PASSWORD=""
EMAIL_FROM="noreply@imboni.gov.rw"

# Firebase (Push Notifications)
FIREBASE_PROJECT_ID=""
FIREBASE_PRIVATE_KEY_PATH=""

# Escalation Deadlines (hours)
ESCALATION_NORMAL_HOURS=48
ESCALATION_HIGH_HOURS=24
ESCALATION_EMERGENCY_HOURS=4

# Environment
NODE_ENV=development
